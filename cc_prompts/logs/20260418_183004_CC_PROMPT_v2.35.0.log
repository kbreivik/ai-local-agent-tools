ON CONFLICT (pattern) DO NOTHING;

-- Audit log for fact-related admin actions
CREATE TABLE IF NOT EXISTS facts_audit_log (
    id           BIGSERIAL PRIMARY KEY,
    action       TEXT NOT NULL,
    fact_key     TEXT,
    actor        TEXT NOT NULL,
    at           TIMESTAMPTZ NOT NULL DEFAULT NOW(),

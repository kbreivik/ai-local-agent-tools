## Change 1 — mcp_server/tools/log_timeline.py (new file)

```python
"""
log_timeline — unified chronological view of everything that happened to an entity.

Merges events from operation_log, agent_actions, entity_history, and Elasticsearch
logs into a single time-sorted list with a normalised schema.
"""
from __future__ import annotations
import datetime as _dt
from typing import Any

from mcp.server.fastmcp import FastMCP
from api.db.base import get_engine
from api.db.infra_inventory import resolve_entity


EVENT_SCHEMA = """\
Each timeline entry has:
  ts:       ISO8601 UTC timestamp
  source:   operation_log | agent_action | entity_history | elastic
  kind:     tool_call | state_change | drift | log_line | plan_executed | ...
  actor:    who/what caused it (agent task_id, user, collector name, log shipper)
  summary:  one-line description
  detail:   structured dict with source-specific fields
"""


def register(mcp: FastMCP) -> None:

    @mcp.tool()
    async def log_timeline(
        entity_id: str,
        window_minutes: int = 60,
        sources: list[str] | None = None,
        limit: int = 200,
    ) -> dict[str, Any]:
        """
        Return a unified event timeline for an entity.

        Args:
            entity_id:       Entity ID in `platform:name:id` form (e.g. `proxmox:worker-03:9203`).
            window_minutes:  How far back to look. Default 60. Max 1440 (24h).
            sources:         Subset of {operation_log, agent_action, entity_history, elastic}.
                             None = all.
            limit:           Max events per source. Default 200.
        """
        window_minutes = min(max(1, window_minutes), 1440)
        since = _dt.datetime.utcnow() - _dt.timedelta(minutes=window_minutes)
        sources = set(sources or ["operation_log", "agent_action", "entity_history", "elastic"])

        # Resolve entity to (platform, name, underlying_id, host, service)
        resolved = resolve_entity(entity_id) or {}
        host     = resolved.get("host") or resolved.get("ip")
        service  = resolved.get("service_name")
        name     = resolved.get("name")

        events: list[dict] = []

        if "operation_log" in sources:
            events.extend(await _from_operation_log(entity_id, name, since, limit))

        if "agent_action" in sources:
            events.extend(await _from_agent_actions(entity_id, name, since, limit))

        if "entity_history" in sources:
            events.extend(await _from_entity_history(entity_id, since, limit))

        if "elastic" in sources and (host or service):
            events.extend(await _from_elastic(host, service, since, limit))

        # Sort descending by ts (most recent first)
        events.sort(key=lambda e: e["ts"], reverse=True)
        events = events[: limit * 2]  # cap overall after merge

        return {
            "entity_id": entity_id,
            "window_minutes": window_minutes,
            "sources_queried": sorted(sources),
            "total": len(events),
            "events": events,
            "schema_note": EVENT_SCHEMA.strip(),
        }


async def _from_operation_log(entity_id, name, since, limit):
    """operation_log rows where entity_id matches OR args reference this entity's name."""
    eng = get_engine()
    rows = []
    async with eng.connect() as c:
        q = """
        SELECT created_at, task_id, tool, args, outcome, duration_ms
        FROM operation_log
        WHERE created_at >= :since
          AND (entity_id = :eid OR args::text ILIKE :name_like)
        ORDER BY created_at DESC
        LIMIT :limit
        """
        rs = await c.execute(q, {
            "since": since,
            "eid": entity_id,
            "name_like": f"%{name}%" if name else "%%",
            "limit": limit,
        })
        rows = rs.mappings().all()
    return [{
        "ts": r["created_at"].isoformat() + "Z",
        "source": "operation_log",
        "kind": "tool_call",
        "actor": f"task:{r['task_id']}",
        "summary": f"{r['tool']} → {r['outcome']} ({r['duration_ms']}ms)",
        "detail": {"tool": r["tool"], "args": r["args"], "outcome": r["outcome"]},
    } for r in rows]


async def _from_agent_actions(entity_id, name, since, limit):
    """agent_actions — destructive actions audit (v2.31.2)."""
    eng = get_engine()
    async with eng.connect() as c:
        q = """
        SELECT created_at, task_id, user_id, tool, args, blast_radius, status, error
        FROM agent_actions
        WHERE created_at >= :since
          AND (entity_id = :eid OR args::text ILIKE :name_like)
        ORDER BY created_at DESC
        LIMIT :limit
        """
        rs = await c.execute(q, {"since": since, "eid": entity_id,
                                 "name_like": f"%{name}%" if name else "%%",
                                 "limit": limit})
        rows = rs.mappings().all()
    return [{
        "ts": r["created_at"].isoformat() + "Z",
        "source": "agent_action",
        "kind": "plan_executed",
        "actor": f"user:{r['user_id']} task:{r['task_id']}",
        "summary": f"{r['tool']} [radius={r['blast_radius']}] → {r['status']}",
        "detail": {"tool": r["tool"], "args": r["args"],
                   "blast_radius": r["blast_radius"],
                   "status": r["status"], "error": r["error"]},
    } for r in rows]


async def _from_entity_history(entity_id, since, limit):
    """entity_history — state transitions + drift events (v2.9.0, v2.33.9)."""
    eng = get_engine()
    async with eng.connect() as c:
        q = """
        SELECT recorded_at, event_type, prev_state, new_state, config_hash, prev_config_hash
        FROM entity_history
        WHERE entity_id = :eid AND recorded_at >= :since
        ORDER BY recorded_at DESC
        LIMIT :limit
        """
        rs = await c.execute(q, {"eid": entity_id, "since": since, "limit": limit})
        rows = rs.mappings().all()
    out = []
    for r in rows:
        kind = "drift" if (r["config_hash"] != r["prev_config_hash"] and r["prev_config_hash"]) else "state_change"
        out.append({
            "ts": r["recorded_at"].isoformat() + "Z",
            "source": "entity_history",
            "kind": kind,
            "actor": "collector",
            "summary": (f"{r['prev_state']} → {r['new_state']}" if kind == "state_change"
                        else f"config_hash {r['prev_config_hash'][:8]}… → {r['config_hash'][:8]}…"),
            "detail": dict(r),
        })
    return out


async def _from_elastic(host, service, since, limit):
    """Elasticsearch log slice — reuse v2.33.11/14 tool internals."""
    from mcp_server.tools.elastic import _run_elastic_search  # internal helper
    body = {
        "query": {
            "bool": {
                "filter": [
                    {"range": {"@timestamp": {"gte": since.isoformat() + "Z"}}},
                ],
            },
        },
        "sort": [{"@timestamp": "desc"}],
        "size": limit,
    }
    if host:
        body["query"]["bool"]["filter"].append(
            {"bool": {"should": [{"term": {"host.name": host}},
                                 {"term": {"host.ip": host}}]}})
    if service:
        body["query"]["bool"]["filter"].append({"term": {"service.name": service}})

    try:
        result = await _run_elastic_search(body)
    except Exception as e:
        return [{
            "ts": _dt.datetime.utcnow().isoformat() + "Z",
            "source": "elastic",
            "kind": "error",
            "actor": "log_timeline",
            "summary": f"elastic query failed: {e}",
            "detail": {},
        }]

    return [{
        "ts": hit.get("_source", {}).get("@timestamp"),
        "source": "elastic",
        "kind": "log_line",
        "actor": hit.get("_source", {}).get("service", {}).get("name") or hit.get("_source", {}).get("host", {}).get("name") or "?",
        "summary": (hit.get("_source", {}).get("message") or "")[:140],
        "detail": {"level": hit.get("_source", {}).get("log", {}).get("level"),
                   "index": hit.get("_index")},
    } for hit in (result.get("hits", {}).get("hits", []) or [])]
```


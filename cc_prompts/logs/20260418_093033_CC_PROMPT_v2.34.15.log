import pytest
from api.security.sanitizer import sanitize_for_llm  # or wherever it lives

class TestSanitizerAllowsLegitimate:
    def test_version_string(self):
        assert sanitize_for_llm("version 2.34.15") == "version 2.34.15"

    def test_large_integer(self):
        assert sanitize_for_llm("tokens_total: 10403") == "tokens_total: 10403"

    def test_container_id(self):
        # Docker short ID, 12 hex chars
        assert sanitize_for_llm("container f3ef70283135") == "container f3ef70283135"

    def test_bare_uuid_in_log(self):
        # UUIDs in log lines are identifiers, not secrets
        assert sanitize_for_llm("operation_id=bf3a71ea-c232-485e-bb8b-e3c9e0f153f5") \
            == "operation_id=bf3a71ea-c232-485e-bb8b-e3c9e0f153f5"


class TestSanitizerBlocksActualSecrets:
    def test_jwt(self):
        text = "Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMjMifQ.abc123def456"
        assert "[REDACTED]" in sanitize_for_llm(text)
        assert "eyJhbGciOiJIUzI1NiJ9" not in sanitize_for_llm(text)

    def test_openai_key(self):
        text = "OPENAI_API_KEY=sk-abc123def456ghi789jklmno012pqr"
        assert "sk-abc123def456" not in sanitize_for_llm(text)

    def test_uuid_in_token_context(self):
        text = 'token="bf3a71ea-c232-485e-bb8b-e3c9e0f153f5"'
        result = sanitize_for_llm(text)
        assert "bf3a71ea" not in result
```

## Change 4 — budget off-by-one

Find the agent loop dispatch point in `api/routers/agent.py` (search for
where tool_calls from the model are executed, likely inside the step loop
after `client.chat.completions.create`).

Current shape is roughly:
```python
for tc in message.tool_calls:
    result = execute_tool(tc)
    tool_call_count += 1
    # ...
```

This dispatches every proposed tool_call in the batch even when the batch
exceeds the budget. Fix:

```python
MAX_TOOLS = _MAX_TOOL_CALLS_BY_TYPE[agent_type]
proposed = list(message.tool_calls or [])
remaining = MAX_TOOLS - tool_call_count

if remaining <= 0:
    # Already at cap — inject a harness message and break
    inject_harness_message(
        f"[harness] Tool budget exhausted ({tool_call_count}/{MAX_TOOLS}). "
        "Produce your final_answer now based on evidence gathered, or call "
        "escalate() if you cannot.",
        role="system",
    )
    break  # out of the step loop; model gets one more chance to synthesise

if len(proposed) > remaining:
    # Truncate the batch to fit within budget; log the truncation
    dropped = proposed[remaining:]
    proposed = proposed[:remaining]
    log.warning(
        "budget truncate operation=%s proposed=%d remaining=%d dropped_tools=%s",
        operation_id, len(message.tool_calls), remaining,
        [t.function.name for t in dropped],
    )
    increment_metric(BUDGET_TRUNCATE_COUNTER, {"agent_type": agent_type})
    # Don't silently drop — tell the model
    inject_harness_message(
        f"[harness] You proposed {len(message.tool_calls)} tool calls but only "
        f"{remaining} fit within your remaining budget. I executed the first "
        f"{remaining}: {[t.function.name for t in proposed]}. "
        f"Skipped: {[t.function.name for t in dropped]}. Continue with what you have.",
        role="system",
    )

for tc in proposed:
    result = execute_tool(tc)
    tool_call_count += 1
    # ...
```

Add metric:
```python
BUDGET_TRUNCATE_COUNTER = Counter(
    "deathstar_agent_budget_truncate_total",
    "Tool-call batches truncated to fit within remaining budget",
    ["agent_type"],
)
```

Add test in `tests/test_agent_budget.py`:

```python
def test_budget_truncate_drops_overflow():
    # Stub: parent at 15/16, model proposes 3 tools
    # Expect: 1 tool executed (remaining), 2 dropped, harness message appended
    ...

def test_budget_exhausted_ends_loop():
    # Stub: parent at 16/16, model proposes 2 tools
    # Expect: 0 tools executed, harness nudge for final_answer, loop breaks
    ...
```


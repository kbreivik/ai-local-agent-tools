## Change 3 — runbook classifier

New file `api/agents/runbook_classifier.py`.

```python
"""
Select the best-matching runbook(s) for a task.

v1: keyword match.
  For each active runbook that applies to the current agent_type:
    score = count of triage_keywords found in task (case-insensitive,
             word-boundary match)
  Pick the single highest-priority runbook with score > 0. Ties broken
  by priority (lower number wins).

Future versions (v2.35.5+):
  - Embedding similarity against runbook titles+keywords
  - LLM classifier for natural-language phrasing
Settings `runbookClassifierMode` gates which mode runs.
"""

import re

def select_runbook(task: str, agent_type: str, settings: dict) -> dict | None:
    mode = settings.get('runbookClassifierMode', 'keyword')
    if mode == 'keyword':
        return _keyword_select(task, agent_type)
    elif mode == 'semantic':
        return _semantic_select(task, agent_type)  # stub for now
    elif mode == 'llm':
        return _llm_select(task, agent_type)       # stub for now
    return None


def _keyword_select(task: str, agent_type: str) -> dict | None:
    candidates = list_active_runbooks_for_agent_type(agent_type)
    if not candidates:
        return None

    task_lower = task.lower()
    scored = []
    for rb in candidates:
        score = 0
        matched_keywords = []
        for kw in (rb.get('triage_keywords') or []):
            if re.search(rf'\b{re.escape(kw.lower())}\b', task_lower):
                score += 1
                matched_keywords.append(kw)
        if score > 0:
            scored.append((score, rb['priority'], rb, matched_keywords))

    if not scored:
        return None

    # Highest score first, then lowest priority number
    scored.sort(key=lambda x: (-x[0], x[1]))
    best = scored[0]
    return {
        'runbook':  best[2],
        'score':    best[0],
        'matched_keywords': best[3],
    }


def _semantic_select(task, agent_type):
    # Stub for v2.35.5 — embedding-based
    return None


def _llm_select(task, agent_type):
    # Stub for v2.35.5 — LLM classifier
    return None
```

## Change 4 — wire runbook into system prompt

In `api/agents/router.py`, extend the system-prompt builder:

```python
def build_system_prompt(
    agent_type: str,
    preflight_facts: list | None = None,
    preflight_trace: list | None = None,
    task: str = '',           # NEW — needed for runbook classifier
    ...
) -> str:
    ...
    # Existing sections (RELEVANT PAST OUTCOMES, TOOL SIGNATURES, etc.)
    sections = [...]

    # NEW: runbook injection
    settings = _get_facts_settings()
    mode = settings.get('runbookInjectionMode', 'off')
    runbook_hit = None
    if mode != 'off' and task:
        runbook_hit = select_runbook(task, agent_type, settings)

    if runbook_hit:
        rb = runbook_hit['runbook']
        RUNBOOK_MATCHES_COUNTER.labels(
            runbook_name=rb['name'], mode=mode,
        ).inc()

        section = (
            f"\n═══ ACTIVE RUNBOOK: {rb['name']} ═══\n"
            f"Title: {rb['title']}\n"
            f"Triggered by keywords: {', '.join(runbook_hit['matched_keywords'])}\n"
            f"Priority: {rb['priority']}\n\n"
            f"{rb['body_md']}\n"
        )

        if mode == 'augment':
            # Inject AFTER existing TRIAGE prompt content
            sections.append(section)
        elif mode == 'replace':
            # Replace the matching TRIAGE section entirely
            sections = _replace_triage_section_with_runbook(sections, rb)
        elif mode == 'replace+shrink':
            # Prompt becomes a thin framework + this runbook
            sections = _build_shrunk_prompt(agent_type, rb)

    return '\n'.join(sections)
```

Keep `replace` and `replace+shrink` stubbed-but-functional: they invoke
helpers that WARN if the target section to replace isn't found. For
v2.35.4's `augment` default behaviour they're not exercised.


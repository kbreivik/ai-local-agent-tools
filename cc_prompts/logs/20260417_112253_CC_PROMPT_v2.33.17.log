profile_id = conn.config.get("credential_profile_id")
if profile_id:
    profile = get_profile_safe(profile_id)  # returns decrypted creds
    username   = conn.credentials.get("username") or profile.get("username")
    key        = profile.get("private_key")
    passphrase = profile.get("passphrase")
    password   = profile.get("password")
else:

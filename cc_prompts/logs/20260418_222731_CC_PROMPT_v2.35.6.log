## Change 3 — regression tests

Add `tests/test_response_egress.py`:

```python
"""v2.35.6 regression tests — ensure no outbound API response sanitisation.

The v2.31.7 sanitiser (format `[BLOCKED: <Category>]`) was supposed to be
retired by v2.34.15 in favour of prompt_sanitiser.py (format `[REDACTED:...]`).
v2.35.6 removed the last remaining legacy call site. These tests lock in the
invariant that no outbound endpoint field ever contains `[BLOCKED:` and that
agent output containing `key=value`-shaped content survives a DB round-trip
unchanged.
"""
from __future__ import annotations

import asyncio
import pytest

from fastapi.testclient import TestClient


@pytest.fixture
def client():
    from api.main import app
    return TestClient(app)


@pytest.fixture
def auth_headers():
    # Minimal stub — projects with real auth should override this.
    # In CI, API_TOKEN_DEFAULT is wired so these requests succeed.
    import os
    return {"Authorization": f"Bearer {os.environ.get('API_TOKEN_DEFAULT', '')}"}


def test_health_version_is_not_blocked(client):
    r = client.get("/api/health")
    assert r.status_code == 200
    body = r.json()
    assert "[BLOCKED:" not in (body.get("version") or ""), \
        f"/api/health version was egress-sanitised: {body.get('version')!r}"
    assert "[REDACTED:" not in (body.get("version") or ""), \
        f"/api/health version should not pass through prompt_sanitiser either"


def test_agent_models_endpoint_clean(client, auth_headers):
    r = client.get("/api/agent/models", headers=auth_headers)
    assert r.status_code == 200
    body_text = r.text
    assert "[BLOCKED:" not in body_text, \
        f"/api/agent/models contains BLOCKED token: {body_text[:300]}"


def test_operations_detail_preserves_key_value_final_answer(client, auth_headers):
    """Regression: a final_answer containing <parameter=x>value</parameter>
    patterns was rewritten to '[BLOCKED: Cookie/query string data]' in v2.35.5.
    """
    from api.db.base import get_engine
    from api import logger as logger_mod
    from sqlalchemy import text
    import uuid

    # Create an operation with a final_answer that matches every pattern the
    # legacy sanitiser flagged: version string, UUID, key=value, XML-like tags.
    op_id = asyncio.get_event_loop().run_until_complete(
        logger_mod.log_operation(str(uuid.uuid4()), "test_egress_preservation", owner_user="test")
    )
    sentinel = (
        "EVIDENCE:\n"
        "- vm_exec(host=ds-docker-worker-03, cmd=docker ps)\n"
        "- <parameter=host>ds-docker-worker-03</parameter>\n"
        "- session_id=abc12345-6789-4321-8765-fedcba987654\n"
        "- version 2.35.6\n"
        "- key=value pairs in prose\n"
        "ROOT CAUSE: test\n"
    )
    asyncio.get_event_loop().run_until_complete(
        logger_mod.set_operation_final_answer(op_id, sentinel)
    )
    # Flush any async writers
    asyncio.get_event_loop().run_until_complete(logger_mod.flush_now())

    # Detail endpoint
    r = client.get(f"/api/logs/operations/{op_id}", headers=auth_headers)
    assert r.status_code == 200, r.text
    op = r.json().get("operation") or {}
    fa = op.get("final_answer") or ""
    assert "[BLOCKED:" not in fa, f"final_answer was egress-sanitised: {fa!r}"
    assert fa == sentinel, (
        f"final_answer round-trip altered: sent {sentinel!r}, got {fa!r}"
    )

    # List endpoint
    r2 = client.get("/api/logs/operations?limit=50", headers=auth_headers)
    assert r2.status_code == 200
    listed = next((o for o in (r2.json().get("operations") or []) if o.get("id") == op_id), None)
    assert listed is not None, "test op not in list response"
    assert "[BLOCKED:" not in (listed.get("final_answer") or "")


def test_prompt_sanitiser_format_is_redacted_not_blocked():
    """Lock in the canonical v2.34.15 sanitiser output format.

    If a future commit reintroduces a '[BLOCKED:' literal anywhere in
    api/security/, this test fails. Prevents the legacy sanitiser from
    silently returning to the codebase.
    """
    from api.security.prompt_sanitiser import sanitise
    text = "JWT eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxIn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c and key=value"
    out, scrubbed = sanitise(text, source_hint="test")
    assert scrubbed is True, "JWT should have triggered a scrub"
    assert "[REDACTED:" in out, f"Expected [REDACTED: token but got {out!r}"
    assert "[BLOCKED:" not in out, f"Legacy [BLOCKED: token must never appear: {out!r}"


def test_no_legacy_sanitiser_module_imports(tmp_path=None):
    """Structural guard: no file in api/ imports a module producing [BLOCKED: ...]."""
    import pathlib
    import re
    root = pathlib.Path(__file__).parent.parent / "api"
    # The canonical sanitiser is the ONLY module allowed to touch secret-like strings
    # in this codebase. Any other module matching these patterns is suspect.
    legacy_token_re = re.compile(r'\[BLOCKED:\s*(?:JWT|Sensitive|Cookie)')
    offenders = []
    for py in root.rglob("*.py"):
        try:
            txt = py.read_text(encoding="utf-8", errors="ignore")
        except Exception:
            continue
        if legacy_token_re.search(txt):
            offenders.append(str(py.relative_to(root)))
    assert offenders == [], (
        f"Legacy '[BLOCKED: ...]' sanitiser format found in: {offenders}. "
        "This module was supposed to be retired by v2.34.15 and deleted in v2.35.6. "
        "Remove it — use api.security.prompt_sanitiser.sanitize_for_llm() instead."
    )
```

These tests cover:
- The live symptoms I saw today (`/api/health`, `/api/agent/models`,

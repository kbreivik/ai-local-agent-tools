```js
    const token = localStorage.getItem('hp1_auth_token')
    if (token) {
      fetch(`${API_BASE}/api/agent/sessions/active`, {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then(r => r.ok ? r.json() : null)

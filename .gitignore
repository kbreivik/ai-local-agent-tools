# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/

# Secrets — never commit
.env
.env.local
.env.*.local
mcp.json
.mcp.json
docker/.env
# .env.defaults IS committed (no secrets, just structure — see .env.defaults)

# Runtime artifacts
logs/*.log
checkpoints/*.json
.code-index/
api/build_info.json
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-bak
data/*.db.bak
data/test_results.json
data/docs_manifest.json
data/ansible_config.json
tests/ansible/inventory.ini

# Ingested document content (keep manifest.json for metadata)
data/docs/*.txt
data/docs/*.html
data/docs/*.pdf

# Skill export artifacts
data/skill_exports/

# GUI build output — built inside Docker, not committed
gui/dist/

# WISC session state — never commit
state/

# Visual companion / brainstorm HTML docs
docs/*.html

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store
.worktrees/

# Claude Code local settings (may contain API keys)
.claude/settings.local.json

# Other tools
.superpowers/
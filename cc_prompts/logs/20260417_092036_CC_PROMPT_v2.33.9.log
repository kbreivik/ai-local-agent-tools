# CC PROMPT — v2.33.9 — Drift detection (config_hash reconciliation)

## What this does
Catches out-of-band config changes — someone SSHes into a manager and runs
`docker service update ...` without going through DEATHSTAR. Compute a
`config_hash` on every entity snapshot; when it changes without a matching
`agent_actions` row within ±60s, flag it as drift. Surface as a ⚠ badge on
the card with a one-click `investigate_drift` sub-task.

Depends on: v2.31.2 (agent_actions table) — already shipped.

Version bump: 2.33.8 → 2.33.9

## Change 1 — api/db/entity_history.py — config_hash column + helper

Extend the existing table (v2.9.0) with a `config_hash` column if missing:

```python
ADD_COLUMN_SQL = """
ALTER TABLE entity_history
ADD COLUMN IF NOT EXISTS config_hash TEXT;
ALTER TABLE entity_history
ADD COLUMN IF NOT EXISTS prev_config_hash TEXT;
CREATE INDEX IF NOT EXISTS idx_entity_history_drift
  ON entity_history(entity_id, snapshot_at)
  WHERE config_hash IS NOT NULL AND config_hash <> COALESCE(prev_config_hash, '');
"""

import hashlib, json

# Keys to exclude — volatile fields unrelated to "intentional" config
_VOLATILE_KEYS = frozenset({
    "uptime", "last_seen", "age_hours", "restart_count",
    "cpu_usage", "memory_usage", "disk_read", "disk_write",
    "network_rx", "network_tx", "fetched_at",
})

def compute_config_hash(metadata: dict | None) -> str:
    if not metadata:
        return ""
    stable = {k: v for k, v in metadata.items() if k not in _VOLATILE_KEYS}
    serialized = json.dumps(stable, sort_keys=True, default=str)
    return hashlib.sha256(serialized.encode()).hexdigest()[:16]

async def record_snapshot(pool, entity_id: str, metadata: dict):
    h = compute_config_hash(metadata)
    async with pool.acquire() as c:
        prev = await c.fetchval("""
            SELECT config_hash FROM entity_history
             WHERE entity_id = $1 ORDER BY snapshot_at DESC LIMIT 1
        """, entity_id)
        await c.execute("""
            INSERT INTO entity_history (entity_id, metadata, config_hash, prev_config_hash, snapshot_at)
            VALUES ($1, $2::jsonb, $3, $4, NOW())
        """, entity_id, json.dumps(metadata), h, prev)
```

Ensure the existing `record_snapshot` path is the only writer so the hash is
always set. If multiple writers exist, add a DB trigger as a safety net.

## Change 2 — api/db/drift_events.py — view + query

```python
"""
Drift events: config_hash changed without a sanctioned agent_action within 60s.
"""

CREATE_VIEW_SQL = """
CREATE OR REPLACE VIEW drift_events AS
SELECT
    eh.entity_id,
    eh.snapshot_at,
    eh.config_hash,
    eh.prev_config_hash,
    eh.metadata
FROM entity_history eh
WHERE eh.config_hash IS NOT NULL
  AND eh.prev_config_hash IS NOT NULL
  AND eh.config_hash <> eh.prev_config_hash
  AND NOT EXISTS (
    SELECT 1
      FROM agent_actions aa
     WHERE aa.entity_id = eh.entity_id
       AND aa.was_planned = TRUE
       AND aa.created_at BETWEEN eh.snapshot_at - INTERVAL '60 seconds'
                             AND eh.snapshot_at + INTERVAL '60 seconds'
  );
"""

async def ensure_view(pool):
    async with pool.acquire() as c:
        await c.execute(CREATE_VIEW_SQL)

async def get_drift_for_entity(pool, entity_id: str, limit: int = 10):
    async with pool.acquire() as c:
        rows = await c.fetch("""
            SELECT snapshot_at, config_hash, prev_config_hash, metadata
              FROM drift_events
             WHERE entity_id = $1
             ORDER BY snapshot_at DESC
             LIMIT $2
        """, entity_id, limit)
        return [dict(r) for r in rows]

async def recent_drift(pool, hours: int = 24, limit: int = 100):
    async with pool.acquire() as c:
        rows = await c.fetch("""
            SELECT entity_id, snapshot_at, config_hash, prev_config_hash
              FROM drift_events
             WHERE snapshot_at > NOW() - ($1 || ' hours')::interval
             ORDER BY snapshot_at DESC
             LIMIT $2
        """, str(hours), limit)
        return [dict(r) for r in rows]
```

Call `ensure_view` in the lifespan startup section of `api/main.py`.

## Change 3 — api/routers/entities.py — /entity/{id}/drift endpoint

```python
from api.db.drift_events import get_drift_for_entity, recent_drift

@router.get("/entity/{entity_id:path}/drift")
async def entity_drift(entity_id: str, request: Request):
    rows = await get_drift_for_entity(request.app.state.pool, entity_id)
    return {"entity_id": entity_id, "events": rows}

@router.get("/drift/recent")
async def drift_recent(hours: int = 24, request: Request = None):
    rows = await recent_drift(request.app.state.pool, hours=hours)
    return {"since_hours": hours, "events": rows, "count": len(rows)}
```


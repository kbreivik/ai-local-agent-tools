                    "volumes": volumes,
                    "last_pull_at": last_pull_at,
                    "running_version": running_version,
                    "built_at": built_at,
                    "dot": dot,
                    "problem": problem,
                    "networks": network_names,
                    "ip_addresses": ip_addresses,
                    "entity_id": f"docker:{name}",
                    "started_at": started_at,
                    "restart_count": restart_count,
                })
```


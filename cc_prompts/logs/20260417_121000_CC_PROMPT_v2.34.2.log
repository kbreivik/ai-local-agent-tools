## Change 1 — new table: skill_executions

```sql
CREATE TABLE skill_executions (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    skill_id        TEXT NOT NULL REFERENCES skills(id) ON DELETE CASCADE,
    task_id         TEXT NOT NULL,
    agent_type      TEXT NOT NULL,
    invoked_by      TEXT,                     -- user_id or 'agent'
    args            JSONB DEFAULT '{}'::jsonb,
    started_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    completed_at    TIMESTAMPTZ,
    duration_ms     INTEGER,
    outcome         TEXT,                     -- success | error | cancelled
    error           TEXT,
    result_summary  TEXT,                     -- first 500 chars of result
    replaced_tool_chain JSONB                 -- optional: tool sequence this skill replaced
);

CREATE INDEX skill_executions_skill_id_idx ON skill_executions (skill_id, started_at DESC);
CREATE INDEX skill_executions_task_id_idx  ON skill_executions (task_id);
```

Alembic migration under `alembic/versions/`.

## Change 2 — instrument skill_execute dispatcher

In whichever file contains the skill dispatch path (likely
`mcp_server/tools/skills/execute.py` or `api/skills/dispatcher.py`), wrap
every invocation:

```python
import datetime as _dt
import uuid as _uuid
from api.db.base import get_engine

async def _record_skill_start(skill_id, task_id, agent_type, invoked_by, args):
    exec_id = _uuid.uuid4().hex[:16]
    eng = get_engine()
    async with eng.begin() as c:
        await c.execute("""
            INSERT INTO skill_executions
                (id, skill_id, task_id, agent_type, invoked_by, args, started_at)
            VALUES (:id, :sid, :tid, :at, :iby, :args, NOW())
        """, {"id": exec_id, "sid": skill_id, "tid": task_id,
              "at": agent_type, "iby": invoked_by, "args": args})
    return exec_id

async def _record_skill_end(exec_id, outcome, result_summary=None, error=None):
    eng = get_engine()
    async with eng.begin() as c:
        await c.execute("""
            UPDATE skill_executions
            SET completed_at = NOW(),
                duration_ms = EXTRACT(EPOCH FROM (NOW() - started_at)) * 1000,
                outcome = :oc,
                error = :err,
                result_summary = :rs
            WHERE id = :id
        """, {"id": exec_id, "oc": outcome, "err": error,
              "rs": (result_summary or "")[:500]})


async def skill_execute(skill_id: str, args: dict, *, task_id: str,
                         agent_type: str, invoked_by: str = "agent"):
    exec_id = await _record_skill_start(skill_id, task_id, agent_type,
                                         invoked_by, args)
    try:
        result = await _run_skill_body(skill_id, args)  # existing logic
        await _record_skill_end(exec_id, "success",
                                  result_summary=str(result)[:500])
        return result
    except Exception as e:
        await _record_skill_end(exec_id, "error", error=str(e)[:500])
        raise
```


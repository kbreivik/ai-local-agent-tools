# HP1 Agent — default environment
# Copy values to .env and fill in your specifics.
# This file is committed to git. .env is not.

DOCKER_HOST=npipe:////./pipe/docker_engine
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
ELASTIC_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601
MUNINN_URL=http://localhost:9475
MUNINN_MCP_URL=http://localhost:9475
MUNINN_VAULT=default
DATABASE_URL=postgresql+asyncpg://hp1user:hp1pass@localhost:5432/hp1_agent
SQLITE_PATH=data/hp1_agent.db
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=
LM_STUDIO_MODEL=lmstudio-community/qwen3-coder-30b-a3b-instruct
SWARM_POLL_INTERVAL=30
KAFKA_POLL_INTERVAL=30
KAFKA_LAG_THRESHOLD=1000
# Kafka under-replicated partition tolerance
# 0 = any under-replicated partition triggers DEGRADED (default)
# N = tolerate up to N under-replicated partitions before DEGRADED
KAFKA_UNDER_REPLICATED_THRESHOLD=0
# Grace period in seconds before under-replication triggers DEGRADED
# 0 = immediate (default). Set to e.g. 120 to ignore brief post-restart lag
KAFKA_UNDER_REPLICATED_GRACE=0
ELASTIC_INDEX_PATTERN=hp1-logs-*
ELASTIC_ERROR_RATE_THRESHOLD=10
ELASTIC_FILEBEAT_STALE_MINUTES=10
ELASTIC_POLL_INTERVAL=60
ENABLE_KIBANA=false
CORRELATION_WINDOW_SECONDS=300
API_HOST=0.0.0.0
API_PORT=8000
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
CORS_ALLOW_ALL=true
AUDIT_LOG_PATH=./logs/audit.log
CHECKPOINT_PATH=./checkpoints

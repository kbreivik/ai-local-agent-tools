@pytest.mark.asyncio
async def test_execution_recorded(seeded_skill):
    """Running a skill writes a row to skill_executions."""
    await skill_execute(seeded_skill.id, {"arg": 1},
                        task_id="t1", agent_type="execute")
    rows = await list_skill_executions(skill_id=seeded_skill.id)
    assert len(rows) == 1
    assert rows[0]["outcome"] == "success"
    assert rows[0]["duration_ms"] > 0

@pytest.mark.asyncio
async def test_error_recorded(failing_skill):
    """Skill that raises → outcome=error, error field populated."""
    with pytest.raises(Exception):
        await skill_execute(failing_skill.id, {}, task_id="t2", agent_type="execute")
    rows = await list_skill_executions(skill_id=failing_skill.id)
    assert rows[0]["outcome"] == "error"
    assert rows[0]["error"]

@pytest.mark.asyncio
async def test_metrics_endpoint_shape(authed_client, seeded_skill):
    r = authed_client.get("/api/skills/metrics?window_days=7")
    assert r.status_code == 200
    d = r.json()
    assert "per_skill" in d
    assert "promoter" in d
    assert "pipeline" in d

def test_window_capped_at_90(authed_client):

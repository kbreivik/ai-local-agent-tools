# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  HP1-AI-Agent — Docker Environment Configuration                           ║
# ║  Copy this file to docker/.env and edit. Values shown are defaults.        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Docker build ──────────────────────────────────────────────────────────────
# Match your host docker group GID: stat -c '%g' /var/run/docker.sock
DOCKER_GID=998

# ── API ───────────────────────────────────────────────────────────────────────
# AGENT_HOST: advertised LAN IP for /api/health network info.
# Required inside Docker (container only sees 172.x bridge IP).
AGENT_HOST=
API_PORT=8000
# ADMIN_USER=admin
ADMIN_PASSWORD=changeme
# JWT_SECRET=<random string — generated automatically if left empty>
# LOG_LEVEL=info     # debug | info | warning | error
# API_WORKERS=1      # Increase behind a load balancer (Swarm ingress)

# ── Local LLM (LM Studio / Ollama / vLLM) ────────────────────────────────────
# Docker Desktop (Win/Mac):   http://host.docker.internal:1234/v1
# Docker on Linux (bridge):   http://172.17.0.1:1234/v1
# Remote machine:             http://192.168.1.100:1234/v1
LM_STUDIO_BASE_URL=
LM_STUDIO_API_KEY=

# ── Skill generation ─────────────────────────────────────────────────────────
# local = LM Studio (airgapped-safe), cloud = Anthropic API, export = sneakernet
SKILL_GEN_BACKEND=local

# ── Cloud LLM (optional, for skill generation) ───────────────────────────────
ANTHROPIC_API_KEY=

# ── Kafka (leave empty to disable Kafka tools) ───────────────────────────────
# Inside Swarm overlay network:  kafka1:9092,kafka2:9092,kafka3:9092
# From host (localhost ports):   localhost:9092,localhost:9093,localhost:9094
KAFKA_BOOTSTRAP_SERVERS=

# ── Elasticsearch (leave empty to disable Elastic tools) ─────────────────────
ELASTIC_URL=
# ELASTIC_INDEX_PATTERN=hp1-logs-*
# ELASTIC_FILEBEAT_STALE_MINUTES=10

# ── Docker daemon (remote Swarm manager) ─────────────────────────────────────
# agent-01 is NOT in the Swarm — it manages manager-01 remotely over TCP.
# Docker daemon TCP API port: 2375 (plain) or 2376 (TLS). 2377 is Swarm control plane only.
# Requires: dockerd on manager-01 started with -H tcp://0.0.0.0:2375 (or systemd override).
DOCKER_HOST=tcp://192.168.199.21:2375

# ── Docker TLS (optional — upgrade from plain TCP 2375 to TLS 2376) ──────────
# Step 1: configure dockerd on manager-01 with TLS certs (see docs/runbooks/docker-tls.md).
# Step 2: set these variables and change DOCKER_HOST port to 2376:
#   DOCKER_HOST=tcp://192.168.199.21:2376
#   DOCKER_TLS_VERIFY=1
#   DOCKER_CERT_PATH=/home/agent/.docker/certs   # directory with ca.pem, cert.pem, key.pem
DOCKER_TLS_VERIFY=
DOCKER_CERT_PATH=

# ── Docker Engine SSH (alternative remote management via SSH tunnel) ──────────
DOCKER_ENGINE_HOST=
DOCKER_ENGINE_USER=root
DOCKER_ENGINE_SSH_KEY=/home/agent/.ssh/id_rsa
# DOCKER_ENGINE_SSH_PORT=22

# ── Proxmox (proxmox_vm_status skill) ────────────────────────────────────────
PROXMOX_HOST=
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=

# ── FortiGate (fortigate_system_status skill) ────────────────────────────────
FORTIGATE_HOST=
FORTIGATE_API_KEY=

# ── MuninnDB (cognitive memory sidecar) ──────────────────────────────────────
# docker-compose.yml runs muninndb + socat proxy on agent-net; 9475 is the external port
MUNINN_URL=http://muninndb:9475

# ── Database / Storage ───────────────────────────────────────────────────────
# Auto-detects PostgreSQL if reachable; falls back to SQLite with no config.
# Option A — full DSN (takes priority over POSTGRES_* vars below)
DATABASE_URL=
# Option B — individual vars (used when DATABASE_URL is empty)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=hp1_agent
POSTGRES_USER=hp1
POSTGRES_PASSWORD=hp1agent
# Option C — Redis cache (optional, agent continues without it if unavailable)
REDIS_URL=
# Force a specific backend: postgres | sqlite  (empty = auto-detect)
STORAGE_BACKEND=

# ── SSH keys ──────────────────────────────────────────────────────────────────
# Host directory mounted as /home/agent/.ssh inside container
SSH_KEY_DIR=~/.ssh

# ── Swarm-only ───────────────────────────────────────────────────────────────
# HP1_IMAGE=hp1-ai-agent:latest
# HP1_REPLICAS=1          # Keep at 1 with SQLite; set >1 only with Postgres
# NFS_SERVER=192.168.1.10 # For multi-node shared volumes

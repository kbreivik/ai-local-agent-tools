                    }}
                  >DISMISS</button>
                )}
                {pullJob.status === 'error' && pullError && (
                  <div style={{ color: 'var(--red)', fontSize: 9, marginTop: 4 }}>{pullError}</div>
                )}
              </div>
            )}
```

### 5i. Disable pull buttons while job active

For each Pull button (`↓ Pull Latest`, `↓ Pull ${selectedTag}`, `↓ Re-pull Image`),
add a `disabled` condition based on pullJob state. Example:


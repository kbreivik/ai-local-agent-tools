## Change 1 — backend permission helpers

New file `api/security/facts_permissions.py`:

```python
from fastapi import HTTPException

def user_has_permission(username: str, user_role: str, action: str, fact_pattern: str) -> bool:
    """
    Returns True if the user is allowed to perform `action` on facts
    matching `fact_pattern`.

    Logic:
      1. sith_lord ALWAYS returns True for any action.
      2. Look up matching rows in known_facts_permissions where
         (grantee_type='user' AND grantee_id=username) OR
         (grantee_type='role' AND grantee_id=user_role).
      3. Filter to rows where revoked=FALSE and (expires_at IS NULL OR expires_at > NOW()).
      4. Match the fact_pattern field against the requested pattern
         (pattern-of-grants covers pattern-of-request; use SQL LIKE
         semantics with * → %).
      5. A user-level grant with revoked=TRUE overrides a role-level
         allow (explicit revoke wins).
    """

def require_permission(action: str, fact_pattern: str):
    """FastAPI dependency factory. Raises 403 if no permission."""
    async def _check(user: str = Depends(get_current_user)):
        # Resolve user → role from users table
        role = get_user_role(user)
        if not user_has_permission(user, role, action, fact_pattern):
            raise HTTPException(403, f"Permission denied: {action} on {fact_pattern}")
        return user
    return _check


def grant_permission(
    grantee_type: str, grantee_id: str,
    action: str, fact_pattern: str,
    granted_by: str, expires_at=None,
) -> int:
    """Insert permission row. Returns new id."""

def revoke_permission(permission_id: int, revoked_by: str) -> None:
    """Mark a grant revoked + audit log."""

def list_permissions(grantee_type: str | None = None, grantee_id: str | None = None) -> list[dict]:
    """For admin UI."""
```

## Change 2 — extend `/api/facts` with admin endpoints

Add to `api/routers/facts.py`:

```python
# Lock management

@router.get("/locks")
async def list_locks(user: str = Depends(get_current_user)):
    """All current locks. Visible to any authenticated user."""
    return {"locks": list_all_locks()}


@router.post("/locks")
async def create_lock(
    body: dict,
    user: str = Depends(require_permission("lock", "<dynamic>")),
):
    """
    Body: {fact_key, locked_value, note}
    Requires 'lock' permission on the fact_pattern matching fact_key.
    """
    _dynamic_permission_check(user, "lock", body["fact_key"])
    lock = create_lock_row(body["fact_key"], body["locked_value"],
                           body.get("note", ""), locked_by=user)
    _audit("lock_created", fact_key=body["fact_key"], actor=user, detail=body)
    FACTS_LOCK_EVENTS_COUNTER.labels(action="created").inc()
    return {"ok": True, "lock": lock}


@router.delete("/locks/{fact_key:path}")
async def remove_lock(fact_key: str, user: str = Depends(get_current_user)):
    _dynamic_permission_check(user, "unlock", fact_key)
    remove_lock_row(fact_key)
    _audit("lock_removed", fact_key=fact_key, actor=user)
    FACTS_LOCK_EVENTS_COUNTER.labels(action="removed").inc()
    return {"ok": True}


# Conflict resolution

@router.post("/conflicts/{conflict_id}/resolve")
async def resolve_conflict(
    conflict_id: int,
    body: dict,   # {resolution: 'keep_lock'|'accept_collector'|'edit_lock', new_value?: ...}
    user: str = Depends(get_current_user),
):
    conflict = get_conflict(conflict_id)
    if not conflict:
        raise HTTPException(404, "Conflict not found")
    _dynamic_permission_check(user, "unlock", conflict["fact_key"])

    resolution = body["resolution"]
    if resolution == "keep_lock":
        mark_conflict_resolved(conflict_id, user, "keep_lock")
    elif resolution == "accept_collector":
        # Update the lock to the collector's value AND update current row
        update_lock(conflict["fact_key"], conflict["offered_value"], user)
        mark_conflict_resolved(conflict_id, user, "accept_collector")
    elif resolution == "edit_lock":
        new_value = body.get("new_value")
        if new_value is None:
            raise HTTPException(400, "edit_lock requires new_value")
        update_lock(conflict["fact_key"], new_value, user)
        mark_conflict_resolved(conflict_id, user, "edit_lock", {"new_value": new_value})
    else:
        raise HTTPException(400, f"Unknown resolution: {resolution}")

    _audit("conflict_resolved", fact_key=conflict["fact_key"], actor=user,
           detail={"resolution": resolution})
    return {"ok": True}


# Permission management (sith_lord only for writes)

@router.get("/permissions")
async def list_perms(user: str = Depends(get_current_user)):
    return {"permissions": list_permissions()}


@router.post("/permissions")
async def grant_perm(
    body: dict,   # {grantee_type, grantee_id, action, fact_pattern, expires_at?}
    user: str = Depends(require_role("sith_lord")),
):
    pid = grant_permission(
        body["grantee_type"], body["grantee_id"],
        body["action"], body["fact_pattern"],
        granted_by=user, expires_at=body.get("expires_at"),
    )
    _audit("permission_granted", actor=user, detail=body)
    return {"ok": True, "permission_id": pid}


@router.delete("/permissions/{permission_id}")
async def revoke_perm(
    permission_id: int,
    user: str = Depends(require_role("sith_lord")),
):
    revoke_permission(permission_id, revoked_by=user)
    _audit("permission_revoked", actor=user, detail={"permission_id": permission_id})
    return {"ok": True}


# Manual fact refresh (re-asserts last_verified)

@router.post("/key/{fact_key:path}/refresh")
async def refresh_manual_fact(
    fact_key: str,
    user: str = Depends(get_current_user),
):
    _dynamic_permission_check(user, "manual_write", fact_key)
    refresh_manual_fact_timestamp(fact_key, actor=user)
    _audit("manual_refresh", fact_key=fact_key, actor=user)
    return {"ok": True}


# Audit log view

@router.get("/audit")
async def list_audit(
    limit: int = Query(100, le=500),
    user: str = Depends(get_current_user),
):
    return {"entries": list_audit_log(limit=limit)}
```


## Change 4 — API endpoints

```python
# api/routers/skills.py (extend)

@router.get("/executions")
async def list_skill_executions(
    skill_id: str | None = None,
    limit: int = 50,
    user = Depends(get_current_user),
):
    eng = get_engine()
    async with eng.connect() as c:
        if skill_id:
            r = await c.execute("""
                SELECT * FROM skill_executions
                WHERE skill_id = :sid
                ORDER BY started_at DESC LIMIT :limit
            """, {"sid": skill_id, "limit": limit})
        else:
            r = await c.execute("""
                SELECT * FROM skill_executions
                ORDER BY started_at DESC LIMIT :limit
            """, {"limit": limit})
        return {"executions": [dict(row) for row in r.mappings().all()]}


@router.get("/metrics")
async def skill_metrics(window_days: int = 7, user = Depends(get_current_user)):
    """Aggregate skill execution + promoter metrics."""
    window_days = min(max(1, window_days), 90)
    since = _dt.datetime.utcnow() - _dt.timedelta(days=window_days)
    eng = get_engine()

    async with eng.connect() as c:
        # Per-skill execution stats
        r = await c.execute("""
            SELECT s.id, s.name, s.created_at,
                   COUNT(e.id)                                     AS execution_count,
                   SUM(CASE WHEN e.outcome='success' THEN 1 ELSE 0 END) AS successes,
                   SUM(CASE WHEN e.outcome='error'   THEN 1 ELSE 0 END) AS errors,
                   AVG(e.duration_ms)                              AS avg_duration_ms,
                   MAX(e.started_at)                               AS last_run
            FROM skills s
            LEFT JOIN skill_executions e ON e.skill_id = s.id AND e.started_at >= :since
            GROUP BY s.id, s.name, s.created_at
            ORDER BY execution_count DESC NULLS LAST, s.name
        """, {"since": since})
        per_skill = [dict(row) for row in r.mappings().all()]

        # Promoter activity
        r = await c.execute("""
            SELECT COUNT(*) AS scans,
                   MAX(scanned_at) AS last_scan,
                   SUM(candidates_new) AS total_new_candidates,
                   SUM(candidates_found) AS total_candidates_seen
            FROM auto_promoter_scans
            WHERE scanned_at >= :since
        """, {"since": since})
        promoter = dict(r.mappings().one())

        # Candidate pipeline state
        r = await c.execute("""
            SELECT status, COUNT(*) AS n
            FROM skill_candidates
            GROUP BY status
        """)
        pipeline = {row["status"]: row["n"] for row in r.mappings().all()}

    return {
        "window_days": window_days,
        "per_skill": per_skill,
        "promoter": promoter,
        "pipeline": pipeline,
    }
```


# HP1 AI Agent — environment variables
# Copy to .env and fill in values. .env is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
# Omit DATABASE_URL to use SQLite (default). Set it to switch to Postgres.
# DATABASE_URL=postgresql+asyncpg://hp1:hp1secret@localhost:5432/hp1agent

# SQLite path (used when DATABASE_URL is unset)
# SQLITE_PATH=D:/claude_code/FAJK/HP1-AI-Agent-v1/data/hp1_agent.db

# ── LM Studio ─────────────────────────────────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=lmstudio-community/qwen3-coder-30b-a3b-instruct
# LM_STUDIO_API_KEY=sk-lm-...   (or set in mcp.json)

# ── Docker Swarm ──────────────────────────────────────────────────────────────
DOCKER_HOST=npipe:////./pipe/docker_engine
SWARM_POLL_INTERVAL=30

# ── Kafka ─────────────────────────────────────────────────────────────────────
# For LAN cluster: replace with actual worker IPs
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_POLL_INTERVAL=30
KAFKA_LAG_THRESHOLD=1000

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Leave ELASTIC_URL unset to disable Elasticsearch monitoring (not an error)
# ELASTIC_URL=http://192.168.1.x:9200
ELASTIC_POLL_INTERVAL=60
FILEBEAT_INDEX_PATTERN=filebeat-*
ELASTIC_INDEX_PATTERN=hp1-logs-*
ELASTIC_ERROR_RATE_THRESHOLD=10    # errors per hour before alert
ELASTIC_FILEBEAT_STALE_MINUTES=10

# ── Kibana (optional) ─────────────────────────────────────────────────────────
ENABLE_KIBANA=false
# KIBANA_URL=http://192.168.1.x:5601

# ── Correlation ───────────────────────────────────────────────────────────────
CORRELATION_WINDOW_SECONDS=300

# ── MuninnDB ──────────────────────────────────────────────────────────────────
# Cognitive memory layer — REST API via socat proxy on port 9475
# Start with: docker compose -f docker-compose.muninndb.yml up -d
MUNINNDB_URL=http://localhost:9475

# ── Agent ─────────────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=./logs/audit.log
CHECKPOINT_PATH=./checkpoints

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ALL=true

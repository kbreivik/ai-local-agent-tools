In `api/db/known_facts.py`, expose:

```python
def init_known_facts() -> None:
    """Create tables + seed refresh schedule defaults."""

def upsert_fact(
    fact_key: str,
    source: str,
    value,                          # JSON-serialisable
    metadata: dict | None = None,
    actor: str = "collector",
) -> dict:
    """
    Upsert a single fact. Returns {action, prior_value, new_value, confidence}.

    Logic:
      1. Check known_facts_locks. If locked with different value,
         write to known_facts_conflicts, return {action: 'conflict'}.
      2. SELECT existing row by (fact_key, source).
      3. If missing: INSERT with verify_count=1, initial confidence.
         Return {action: 'insert'}.
      4. If present and value unchanged: UPDATE last_verified,
         verify_count++, recompute confidence. Return {action: 'touch'}.
      5. If present and value changed: WRITE history row, UPDATE current
         with new value + verify_count=1 + change_detected=TRUE +
         change_flagged_at=NOW. Return {action: 'change'}.
      6. If conflicting with another SOURCE's current value (different
         source, same fact_key): append to each row's `contradicts`
         array. Return {action: 'contradict'} in addition to insert/change.
    """

def batch_upsert_facts(facts: list[dict], actor: str = "collector") -> dict:
    """Batch version. Returns totals per action kind."""

def get_fact(fact_key: str, min_confidence: float = 0.0) -> list[dict]:
    """Return all rows for a fact_key across sources, above min_confidence."""

def get_confident_facts(
    pattern: str | None = None,
    min_confidence: float = 0.7,
    max_rows: int = 40,
) -> list[dict]:
    """Return top rows by confidence. Pattern uses SQL LIKE semantics
    with * → %."""

def get_pending_conflicts() -> list[dict]:
    """Return unresolved conflicts for the Dashboard badge + UI."""

def get_recently_changed(hours: int = 24) -> list[dict]:
    """Rows with change_detected=TRUE and change_flagged_at within window."""

def compute_confidence(row: dict) -> float:
    """Deterministic confidence scoring. See formula below."""

def clear_change_flag(fact_key: str, source: str) -> None:
    """Reset change_detected after UI ack or after TTL expiry."""

def get_stale_facts(pattern: str | None = None) -> list[dict]:
    """Facts past their refresh cadence. Uses known_facts_refresh_schedule."""
```

### Confidence formula — deterministic

```python
import math
from datetime import datetime, timezone

def compute_confidence(row: dict, settings: dict | None = None) -> float:
    """
    Compute confidence score in [0.0, 1.0].

    Inputs (all from row):
      - source:          str
      - last_verified:   datetime
      - verify_count:    int
      - contradicts:     list of {source, value, seen_at}

    Settings (falls back to spec defaults if None):
      - factSourceWeight_<source>: float
      - factHalfLifeHours_<source_class>: float
      - factVerifyCountCap: int
    """
    settings = settings or _get_facts_settings()

    # Source weight, with per-source override
    weight_key = f"factSourceWeight_{row['source']}"
    base = settings.get(weight_key, _default_source_weight(row['source']))

    # Age decay (exponential, half-life driven)
    hours_since = (_now() - row["last_verified"]).total_seconds() / 3600
    half_life = _half_life_for_source(row["source"], settings)
    age_factor = 0.5 ** (hours_since / half_life) if half_life > 0 else 1.0

    # Verify count boost (logarithmic, diminishing returns)
    cap = settings.get("factVerifyCountCap", 10)
    vc = min(row.get("verify_count", 1), cap)
    verify_boost = min(0.2, 0.05 * math.log2(vc + 1))

    # Contradiction penalty (largest weighted disagreement counts)
    penalty = 0.0
    for c in row.get("contradicts", []):
        c_weight = settings.get(
            f"factSourceWeight_{c.get('source','unknown')}",
            0.5,
        )
        penalty = max(penalty, 0.1 * c_weight)

    return max(0.0, min(1.0, base * age_factor + verify_boost - penalty))


_DEFAULT_SOURCE_WEIGHTS = {
    "manual":                 1.0,
    "proxmox_collector":      0.9,
    "swarm_collector":        0.9,
    "docker_agent_collector": 0.85,
    "pbs_collector":          0.85,
    "fortiswitch_collector":  0.85,
    "kafka_collector":        0.8,
    "agent_observation":      0.5,
    "rag_extraction":         0.4,
}

_DEFAULT_HALF_LIVES = {
    "manual":            720.0,      # 30d phase-1 shelf
    "agent_observation": 24.0,
    "rag_extraction":    720.0,
    # collectors default to 168h (7d) via _half_life_for_source fallback
}
```

Manual facts: the spec defines a phased decay. Implement as:
- `last_verified` within 30d: half-life = 720h (decay is gentle in that window)
- `last_verified` 30-60d old: half-life = 1440h (decay steepens)
- `last_verified` > 60d: half-life = 1440h (continues to fade but never disappears)

Don't try to be fancy; two conditional half-lives based on age is fine.

## Change 2 — collector-side fact extractors

New file `api/facts/extractors.py`. One function per collector. Each
takes the collector's snapshot dict and returns a list of fact dicts
ready for `batch_upsert_facts()`.

```python
def extract_facts_from_proxmox_vm_snapshot(snapshot: dict, connection_label: str) -> list[dict]:
    """From proxmox_vms collector snapshot → fact list."""
    facts = []
    for vm in snapshot.get("vms", []):
        fkey_base = f"prod.proxmox.vm.{vm['name']}"
        facts.append({
            "fact_key": f"{fkey_base}.status",
            "source":   "proxmox_collector",
            "value":    vm["status"],
            "metadata": {"vmid": vm["vmid"], "connection": connection_label},
        })
        facts.append({
            "fact_key": f"{fkey_base}.node",
            "source":   "proxmox_collector",
            "value":    vm["node"],
            "metadata": {"vmid": vm["vmid"]},
        })
        if vm.get("ip_address"):
            facts.append({
                "fact_key": f"{fkey_base}.ip",
                "source":   "proxmox_collector",
                "value":    vm["ip_address"],
            })
        # Add: cpu_count, memory_mb, disk_gb if present in snapshot
    return facts


def extract_facts_from_swarm_snapshot(snapshot: dict) -> list[dict]:
    facts = []
    for svc in snapshot.get("services", []):
        fkey_base = f"prod.swarm.service.{svc['name']}"
        facts.append({
            "fact_key": f"{fkey_base}.replicas.desired",
            "source":   "swarm_collector",
            "value":    svc.get("replicas_desired"),
            "metadata": {"service_id": svc.get("id")},
        })
        facts.append({
            "fact_key": f"{fkey_base}.replicas.running",
            "source":   "swarm_collector",
            "value":    svc.get("replicas_running"),
        })
        if svc.get("placement"):
            facts.append({
                "fact_key": f"{fkey_base}.placement",
                "source":   "swarm_collector",
                "value":    svc["placement"],  # list of node names
            })
        if svc.get("image"):
            facts.append({
                "fact_key": f"{fkey_base}.image",
                "source":   "swarm_collector",
                "value":    svc["image"],
            })
    return facts


def extract_facts_from_docker_agent_snapshot(snapshot: dict) -> list[dict]:
    """Local agent-01 docker collector."""
    facts = []
    for c in snapshot.get("containers", []):
        if not c.get("id"):
            continue
        fkey_base = f"prod.container.{c['id'][:12]}"  # short ID
        facts.append({
            "fact_key": f"{fkey_base}.service_name",
            "source":   "docker_agent_collector",
            "value":    c.get("name") or c.get("service_name"),
        })
        if c.get("image"):
            facts.append({
                "fact_key": f"{fkey_base}.image",
                "source":   "docker_agent_collector",
                "value":    c["image"],
            })
        if c.get("state"):
            facts.append({
                "fact_key": f"{fkey_base}.state",
                "source":   "docker_agent_collector",
                "value":    c["state"],
            })
        if c.get("networks"):
            facts.append({
                "fact_key": f"{fkey_base}.networks",
                "source":   "docker_agent_collector",
                "value":    c["networks"],  # dict of network → IP
            })
    return facts


def extract_facts_from_kafka_snapshot(snapshot: dict) -> list[dict]:
    facts = []
    for b in snapshot.get("brokers", []):
        fkey_base = f"prod.kafka.broker.{b['id']}"
        facts.append({
            "fact_key": f"{fkey_base}.host",
            "source":   "kafka_collector",
            "value":    b["host"],
        })
        facts.append({
            "fact_key": f"{fkey_base}.port",
            "source":   "kafka_collector",
            "value":    b["port"],
        })
        facts.append({
            "fact_key": f"{fkey_base}.is_controller",
            "source":   "kafka_collector",
            "value":    b.get("is_controller", False),
        })
    for t in snapshot.get("topics", []):
        facts.append({
            "fact_key": f"prod.kafka.topic.{t['name']}.partitions",
            "source":   "kafka_collector",
            "value":    t.get("partition_count"),
        })
        facts.append({
            "fact_key": f"prod.kafka.topic.{t['name']}.replication_factor",
            "source":   "kafka_collector",
            "value":    t.get("replication_factor"),
        })
    return facts


def extract_facts_from_pbs_snapshot(snapshot: dict) -> list[dict]:
    facts = []
    for backup in snapshot.get("backups", []):
        fkey_base = f"prod.pbs.backup.{backup['id']}"
        if backup.get("last_success_ts"):
            facts.append({
                "fact_key": f"{fkey_base}.last_success_ts",
                "source":   "pbs_collector",
                "value":    backup["last_success_ts"],
            })
        facts.append({
            "fact_key": f"{fkey_base}.vm_id",
            "source":   "pbs_collector",
            "value":    backup.get("vm_id"),
        })
    return facts


def extract_facts_from_fortiswitch_snapshot(snapshot: dict) -> list[dict]:
    facts = []
    for sw in snapshot.get("switches", []):
        fkey_base = f"prod.fortiswitch.{sw['serial']}"
        facts.append({
            "fact_key": f"{fkey_base}.model",
            "source":   "fortiswitch_collector",
            "value":    sw.get("model"),
        })
        facts.append({
            "fact_key": f"{fkey_base}.firmware",
            "source":   "fortiswitch_collector",
            "value":    sw.get("firmware"),
        })
        facts.append({
            "fact_key": f"{fkey_base}.mac_addresses",
            "source":   "fortiswitch_collector",
            "value":    sw.get("mac_addresses", []),
        })
    return facts
